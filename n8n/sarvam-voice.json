        },
        "options": {}
      },
      "id": "sendVoice",
      "name": "HTTP \u00b7 Send voice reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2860,
        -60
      ],
      "onError": "continueRegularOutput"
    },
    {
