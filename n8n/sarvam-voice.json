              "id": "c2",
              "leftValue": "={{ $json.hasTts }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "ifHasTts",
      "name": "IF \u00b7 Has audio?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2420,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst base64Audio = item.base64Audio || '';\nif (!base64Audio) return [{ json: { ...item, _ttsOk: false } }];\nreturn [{\n  json: { ...item, _ttsOk: true },\n  binary: {\n    data: {\n      data: base64Audio,\n      mimeType: 'audio/mpeg',\n      fileName: 'voice-reply.mp3',\n      fileExtension: 'mp3'\n    }\n  }\n}];"
      },
      "id": "b64toBin",
      "name": "Code \u00b7 Base64 to binary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2640,
