      ],
      "parameters": {
        "jsCode": "const c = $('When called by engine').first().json;\nconst body = c._body || {};\nconst upsertResult = $('HTTP · Upsert lead').first().json;\nconst leadId = c.leadId || upsertResult.Id || upsertResult.id || '';\nreturn [{ json: {\n  client_id: String(c.client_id || ''),\n  phone: c.phone || '',\n  name: c.name || '',\n  stage: body.Stage || c.stage || '',\n  nba_score: (body.QualScore || 0) * 10,\n  lead_id: String(leadId),\n  is_new_lead: c._method === 'POST'\n} }];"
      }
    },
