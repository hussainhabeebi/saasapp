          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ content: $json.message, message_type: 'outgoing', private: false }) }}",
        "options": {}
      },
      "id": "or-send-existing",
      "name": "HTTP · Send to Existing Conv",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [300, -80],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.chatwoot_base }}/api/v1/accounts/{{ $json.chatwoot_account_id }}/contacts/search?q={{ $json.phone }}&include_contacts=true",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "api_access_token", "value": "={{ $json.chatwoot_token }}" }
          ]
        },
        "options": {}
      },
      "id": "or-search-contact",
      "name": "HTTP · Search Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [300, 80],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const ctx  = $('Code · Build Message').first().json;\nconst res  = $input.first().json;\n// Chatwoot contact search returns { payload: [{ id, name, phone_number }] }\nconst contacts = res.payload || res.contacts || [];\nconst contact  = contacts.find(c => (c.phone_number||'').replace(/[^0-9]/g,'').includes(ctx.phone) || ctx.phone.includes((c.phone_number||'').replace(/[^0-9]/g,'')));\nconst contactId = contact?.id || null;\nreturn [{ json: { ...ctx, contactId } }];"
      },
      "id": "or-pick-contact",
      "name": "Code · Pick Contact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 80]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "version": 2 },
          "conditions": [
            {
              "id": "has-contact",
              "leftValue": "={{ $json.contactId }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "or-has-contact",
      "name": "If · Has Contact",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [740, 80]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Code · Build Message').first().json.chatwoot_base }}/api/v1/accounts/{{ $('Code · Build Message').first().json.chatwoot_account_id }}/contacts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "api_access_token", "value": "={{ $('Code · Build Message').first().json.chatwoot_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ name: $('Code · Build Message').first().json.customerName, phone_number: '+' + $('Code · Build Message').first().json.phone }) }}",
        "options": {}
      },
      "id": "or-create-contact",
      "name": "HTTP · Create Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 160],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Code · Build Message').first().json;\n// contactId from search OR from newly created contact\nlet contactId = null;\ntry { contactId = $('Code · Pick Contact').first().json.contactId; } catch(e) {}\nif (!contactId) {\n  try { contactId = $input.first().json.id || $input.first().json.payload?.id; } catch(e) {}\n}\nreturn [{ json: { ...ctx, contactId } }];"
      },
      "id": "or-merge-contact",
      "name": "Code · Merge Contact ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1180, 80]
