        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ inbox_id: parseInt($('Code · Build Message').first().json.chatwoot_inbox_id), contact_id: $json.contactId }) }}",
        "options": {}
      },
