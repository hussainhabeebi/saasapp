      "position": [1560, 560],
      "parameters": {
        "workflowId": { "cachedResultName": "Leadvyne · Engine · Consulting & HR", "__rl": true, "mode": "name" },
        "options": {}
      }
    },
    {
      "id": "exec-general",
      "name": "Execute · General Engine",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [1560, 720],
      "parameters": {
        "workflowId": { "cachedResultName": "Leadvyne · Engine · General", "__rl": true, "mode": "name" },
        "options": {}
      }
    }
  ],

