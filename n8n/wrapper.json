      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst b = raw.body || raw;\n// Drop non-incoming and private messages early\nif (b.message_type && b.message_type !== 'incoming') return [];\nif (b.private) return [];\nconst client_id = String(raw.client_id || b.client_id || '');\nif (!client_id) return [];\n// Pass full raw payload through so engine can re-use it\nreturn [{ json: { ...raw, client_id } }];"
      }
    },
