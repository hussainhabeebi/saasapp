    {
      "parameters": {
        "jsCode": "const s   = $('Set · Settings').first().json;\nconst b   = $('Webhook · Onboard').first().json.body;\nconst row = $input.first().json;\nconst clientId = row.Id || row.id || row.ncRecordId;\nconst slug = ('c-' + b.chatwoot_inbox_id + '-' + clientId).replace(/[^a-zA-Z0-9_-]/g,'');\nconst engineId = s.engine_workflow_id;\n\nconst wrapper = {\n  name: 'Bot · ' + (b.client_name || ('client-'+clientId)) + ' (#' + clientId + ')',\n  nodes: [\n    { parameters:{ httpMethod:'POST', path: slug, responseMode:'responseNode', options:{} },\n      name:'Webhook', type:'n8n-nodes-base.webhook', typeVersion:2, position:[0,0], webhookId: slug },\n    { parameters:{ respondWith:'json', responseBody:'={ \"ok\": true }', options:{} },\n      name:'Respond ACK', type:'n8n-nodes-base.respondToWebhook', typeVersion:1.1, position:[0,200] },\n    { parameters:{ assignments:{ assignments:[ { id:'cid', name:'client_id', value:String(clientId), type:'string' } ] }, includeOtherFields:true, options:{} },\n      name:'Set client_id', type:'n8n-nodes-base.set', typeVersion:3.4, position:[260,0] },\n    { parameters:{ workflowId:{ __rl:true, value: engineId, mode:'id' }, options:{} },\n      name:'Run engine', type:'n8n-nodes-base.executeWorkflow', typeVersion:1.2, position:[520,0] }\n  ],\n  connections: {\n    'Webhook': { main: [ [ { node:'Respond ACK', type:'main', index:0 }, { node:'Set client_id', type:'main', index:0 } ] ] },\n    'Set client_id': { main: [ [ { node:'Run engine', type:'main', index:0 } ] ] }\n  },\n  settings: { executionOrder:'v1' }\n};\n\nconst webhook_url = s.n8n_base.replace(/\\/$/,'') + '/webhook/' + slug;\nreturn [{ json: { wrapper, webhook_url, clientId } }];"
      },
